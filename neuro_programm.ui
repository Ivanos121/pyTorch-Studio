         <property name="styleSheet">
          <string notr="true">QPushButton {
    border: none;                  /* Полностью убираем рамку */
    background-color: transparent; /* Делаем фон прозрачным */
    color: #1a1a1a;                /* Цвет текста (темно-серый) */
    padding: 5px 12px;             /* Свободные внутренние отступы */
    font-family: &quot;Monospace&quot;;
    font-size: 13px;
    border-radius: 2px;            /* Едва заметное строгое скругление */
}
QPushButton {
    /* solid означает сплошную линию, 1px — толщину, #b0b0b0 — серый цвет рамки */
    border: 1px solid #b0b0b0;    
    background-color: #ffffff;    /* Белый фон внутри кнопки */
    color: #1a1a1a;
    padding: 5px 12px;
    border-radius: 2px;           /* Минимальное строгое скругление углов */
}

/* При наведении мыши рамка красиво подсвечивается синим цветом Breeze */
QPushButton:hover {
    border: 1px solid #3daee9;    /* Синий цвет рамки при наведении */
    background-color: #f7fcfe;    /* Едва заметный синеватый фон */
}

/* При нажатии рамка и фон становятся более насыщенными */
QPushButton:pressed {
    border: 1px solid #1b75a6;
    background-color: #cce4f7;
    color: #0056b3;
}

/* Эффект при наведении мыши (Hover) */
QPushButton:hover {
    background-color: #e0e0e0;     /* Светло-серый аккуратный фон */
}

/* Эффект при физическом клике (Pressed) */
QPushButton:pressed {
    background-color: #cce4f7;     /* Нежно-синяя подсветка нажатия */
    color: #0056b3;                /* Текст становится синим */
}

/* Если кнопка заблокирована (Disabled) */
QPushButton:disabled {
    color: #aaaaaa;                /* Серый блеклый текст */
    background-color: transparent;
}
</string>
