          <property name="styleSheet">
           <string notr="true">QProgressBar {
    border: 1px solid #b0b0b0;
    border-radius: 4px;        /* Красивое скругление толстой шкалы */
    text-align: center;         /* Проценты % ровно по центру полосы */
    background-color: #eff0f1;  /* Серый фон Breeze */
    color: #232629;             /* Контрастный цвет цифр */
    font-family: &quot;Monospace&quot;;
    font-weight: bold;
    font-size: 13px;
}

QProgressBar::chunk {
    /* Живой градиент нагрузки: от зеленого через желтый к боевому красному */
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                      stop:0 #2ecc71,   /* 0% - 50%: Зеленый */
                                      stop:0.6 #f1c40f,  /* 50% - 75%: Желтый */
                                      stop:0.85 #e67e22, /* 75% - 90%: Оранжевый */
                                      stop:1.0 #e74c3c); /* 90% - 100%: Красный */
    border-radius: 3px;
}
</string>
